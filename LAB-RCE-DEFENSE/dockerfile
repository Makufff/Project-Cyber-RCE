# ============================================================
# LAB-RCE-DEFENSE: Next.js RSC Flight Protocol RCE Challenge
# ============================================================
# Vulnerable: Next.js 15.0.4 (RSC Flight Protocol RCE)
# Goal:       Upgrade Next.js to a patched version
# Verify:     Run 'submit' to check if the RCE is fixed
# ============================================================

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Bangkok
ENV NODE_ENV=development

# -----------------------------------------------------------
# 1. Base system setup (full Ubuntu with dev tools)
# -----------------------------------------------------------
RUN apt-get update \
    && apt-get install -y unminimize \
    && rm -rf /var/lib/apt/lists/* \
    && yes | unminimize

RUN apt-get update && apt-get upgrade -y && \
    apt-get install -y \
    openssh-server apt-file apt-utils iproute2 iputils-ping \
    sudo htop iputils* acl tzdata net-tools vim nano curl git \
    tini tmux jq

# -----------------------------------------------------------
# 2. Install Node.js 20 LTS
# -----------------------------------------------------------
RUN curl -fsSL https://nodejs.org/dist/v20.18.0/node-v20.18.0-linux-x64.tar.gz \
    | tar -xzf - -C /usr/local --strip-components=1 --no-same-owner

# -----------------------------------------------------------
# 3. Create lab user
# -----------------------------------------------------------
RUN useradd -m -s /bin/bash secspace && \
    echo 'secspace:secspace' | chpasswd && \
    usermod -aG sudo secspace && \
    usermod -U secspace && \
    echo 'root:supersecret_password' | chpasswd && \
    usermod -U root

# -----------------------------------------------------------
# 4. SSH server config
# -----------------------------------------------------------
RUN mkdir /var/run/sshd && \
    sed -i 's/^#\(PermitRootLogin \).*/\1yes/' /etc/ssh/sshd_config && \
    sed -i 's/^#\(PasswordAuthentication \).*/\1yes/' /etc/ssh/sshd_config && \
    sed -i 's/^#\(KbdInteractiveAuthentication \).*/\1yes/' /etc/ssh/sshd_config && \
    sed 's@session\s*required\s*pam_loginuid.so@session optional pam_loginuid.so@g' -i /etc/pam.d/sshd && \
    echo "export VISIBLE=now" >> /etc/profile

RUN echo 'secspace ALL=(ALL) NOPASSWD: ALL' | tee -a /etc/sudoers

# -----------------------------------------------------------
# 5. Create VULNERABLE Next.js app (v15.0.4)
#    This version is vulnerable to RSC Flight Protocol RCE
# -----------------------------------------------------------
WORKDIR /home/secspace

RUN npm exec -- create-next-app@15.0.4 app \
    --yes \
    --use-npm \
    --typescript \
    --eslint \
    --app \
    --no-tailwind \
    --no-src-dir \
    --import-alias "@/*" \
    && chown -R secspace:secspace app

USER secspace
WORKDIR /home/secspace/app

RUN npm install

# -----------------------------------------------------------
# 6. Place the secret flag (RCE target)
# -----------------------------------------------------------
RUN echo "cve{nextjs-flight-protocol-issue-defended}" > .rng_secret

USER root

# -----------------------------------------------------------
# 7. Install submit verification script
#    Decodes from base64 → /usr/local/bin/submit
#    The script:
#      [1/3] Detects installed Next.js version
#      [2/3] Checks if dev server is running (with retries)
#      [3/3] Sends RSC Flight Protocol RCE payload
#      → If secret leaked:  FAILED  (still vulnerable)
#      → If secret safe:    PASSED  (patched!)
# -----------------------------------------------------------
RUN echo "" \
    | base64 -d > /usr/local/bin/submit \
    && chmod +x /usr/local/bin/submit

# -----------------------------------------------------------
# 8. Helper script: restart dev server after upgrade
# -----------------------------------------------------------
RUN echo '#!/bin/bash' > /usr/local/bin/restart-app && \
    echo 'echo "Stopping existing Next.js server..."' >> /usr/local/bin/restart-app && \
    echo 'tmux kill-session -t nextjs 2>/dev/null' >> /usr/local/bin/restart-app && \
    echo 'sleep 1' >> /usr/local/bin/restart-app && \
    echo 'echo "Starting Next.js dev server..."' >> /usr/local/bin/restart-app && \
    echo 'export RNG_SECRET=$(cat /home/secspace/app/.rng_secret)' >> /usr/local/bin/restart-app && \
    echo 'cd /home/secspace/app && tmux new-session -d -s nextjs "export RNG_SECRET=$(cat /home/secspace/app/.rng_secret) && npm run dev"' >> /usr/local/bin/restart-app && \
    echo 'echo "Waiting for server to start..."' >> /usr/local/bin/restart-app && \
    echo 'sleep 5' >> /usr/local/bin/restart-app && \
    echo 'echo "Done! Run: submit"' >> /usr/local/bin/restart-app && \
    chmod +x /usr/local/bin/restart-app

EXPOSE 22 3000

ENTRYPOINT ["/usr/bin/tini", "--"]

CMD ["/bin/bash", "-c", "/usr/sbin/sshd && su - secspace -c 'tmux new-session -d -s nextjs \"export RNG_SECRET=$(cat /home/secspace/app/.rng_secret) && cd /home/secspace/app && npm run dev\"' && tail -f /dev/null"]
